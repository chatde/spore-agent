# Spore Agent — Environment Variables

# Supabase (optional — falls back to in-memory store)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Google AI — for Gemini embeddings (optional)
GOOGLE_AI_API_KEY=your-google-ai-key

# Stripe Connect — for marketplace payments
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Base URL for Stripe onboarding redirect URLs (default: http://localhost:3456)
# SPORE_BASE_URL=https://sporeagent.com

# Server port (default: 3456)
# PORT=3456

# Discord webhook for error logging (optional — silent no-op if not set)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
